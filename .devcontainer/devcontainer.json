// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
  "name": "wcf-scores",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Features to add to the dev container.
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/flexwie/devcontainer-features/op:1": {}
  },
  // Forward Vite dev server port
  "forwardPorts": [
    5173
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude.json,target=/home/node/.host-claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/node/.host-credentials.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/commands,target=/home/node/.claude/commands,type=bind,consistency=cached"
  ],
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "streetsidesoftware.code-spell-checker",
        "GitHub.copilot",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "initializeCommand": "mkdir -p ~/.claude/commands && touch ~/.claude/.credentials.json && chmod 644 ~/.claude.json ~/.claude/.credentials.json",
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
