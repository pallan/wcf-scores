// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
  "name": "wcf-scores",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  // Features to add to the dev container.
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/flexwie/devcontainer-features/op:1": {}
  },
  // Forward Vite dev server port
  "forwardPorts": [
    5173
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  // Mounts: bind targeted ~/.claude files/dirs from host so credentials/config are available
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=wcf-scores-claude-plugins,target=/home/node/.claude/plugins,type=volume",
    "source=wcf-scores-history,target=/commandhistory,type=volume"
  ],
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "streetsidesoftware.code-spell-checker",
        "GitHub.copilot",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  // Install Claude Code via native installer
  "initializeCommand": "mkdir -p ~/.claude/commands ~/.claude/projects && touch ~/.claude/.credentials.json ~/.claude/settings.json ~/.claude/.claude.json",
  "postCreateCommand": "mkdir -p ~/.npm-global && npm config set prefix ~/.npm-global && npm install -g @anthropic-ai/claude-code && echo 'export PATH=$HOME/.npm-global/bin:$PATH' >> ~/.bashrc"
}
