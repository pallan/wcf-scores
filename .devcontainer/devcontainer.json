// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
  "name": "wcf-scores",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  // Features to add to the dev container.
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/flexwie/devcontainer-features/op:1": {}
  },
  // Forward Vite dev server port
  "forwardPorts": [
    5173
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  // Mounts: bind targeted ~/.claude files/dirs from host so credentials/config are available
  "mounts": [
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/node/.claude/.credentials.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/node/.claude/settings.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/.claude.json,target=/home/node/.claude/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/commands,target=/home/node/.claude/commands,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/projects,target=/home/node/.claude/projects,type=bind,consistency=cached",
    "source=wcf-scores-history,target=/commandhistory,type=volume"
  ],
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "streetsidesoftware.code-spell-checker",
        "GitHub.copilot",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  // Install Claude Code via native installer
  "postCreateCommand": "curl -fsSL https://claude.ai/install.sh | bash"
}
